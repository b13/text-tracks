{
    "name": "b13/text-tracks",
    "description": "Add Text Track Files (CTT) to videos within TYPO3",
    "type": "typo3-cms-extension",
    "license": [
        "GPL-2.0-or-later"
    ],
    "require": {
		"php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "saschaegerer/phpstan-typo3": "^2.0 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "B13\\TextTracks\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "text_tracks"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
